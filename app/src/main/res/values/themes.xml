<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.StoryPop" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryVariant">@color/primaryDarkColor</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/secondaryColor</item>
        <item name="colorSecondaryVariant">@color/secondaryDarkColor</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorOnBackground">@color/textPrimary</item>

        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
        <item name="android:textColorTertiary">@color/textTertiary</item>
        <item name="android:textColorHint">@color/textTertiary</item>
        <item name="android:textColorLink">@color/secondaryColor</item>

        <item name="colorControlNormal">@color/gray</item>
        <item name="colorControlActivated">@color/secondaryColor</item>
        <item name="colorControlHighlight">@color/secondaryColor</item>
        <item name="colorSwitchThumbNormal">@color/white</item>
        <item name="colorError">@color/colorError</item>

        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <item name="android:actionBarStyle">@style/Widget.StoryPop.ActionBar</item>
        <item name="actionBarStyle">@style/Widget.StoryPop.ActionBar</item>
        <item name="toolbarStyle">@style/Widget.StoryPop.Toolbar</item>
        <item name="materialButtonStyle">@style/Widget.StoryPop.Button</item>
        <item name="borderlessButtonStyle">@style/Widget.StoryPop.Button.TextButton</item>
        <item name="android:buttonStyle">@style/Widget.StoryPop.Button</item>
        <item name="cardViewStyle">@style/Widget.StoryPop.CardView</item>
        <item name="android:dialogTheme">@style/Theme.StoryPop.Dialog</item>
        <item name="android:alertDialogTheme">@style/Theme.StoryPop.Dialog.Alert</item>
        <item name="bottomSheetDialogTheme">@style/Theme.StoryPop.BottomSheetDialog</item>
        <item name="android:popupMenuStyle">@style/Widget.StoryPop.PopupMenu</item>
        <item name="android:progressBarStyle">@style/Widget.StoryPop.ProgressBar</item>
        <item name="colorPrimaryDark">@color/primaryDarkColor</item>
        <item name="colorAccent">@color/secondaryColor</item>

        <item name="tagBackground">@color/tagBackground</item>
        <item name="tagIconColor">@color/tagIconColor</item>
        <item name="tagTextColor">@color/tagTextColor</item>
        <item name="tagBackgroundEdit">@color/tagBackgroundEdit</item>
        <item name="tagBorderEdit">@color/tagBorderEdit</item>
        <item name="tagIconColorEdit">@color/tagIconColorEdit</item>
        <item name="tagTextColorEdit">@color/tagTextColorEdit</item>
        <item name="tagRemoveIconColor">@color/tagRemoveIconColor</item>
    </style>

    <style name="Theme.StoryPop.NoActionBar" parent="Theme.StoryPop">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="Theme.StoryPop.Fullscreen" parent="Theme.StoryPop">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="Theme.StoryPop.Dialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondaryColor</item>
        <item name="android:colorBackground">@color/colorSurface</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
    </style>

    <style name="Theme.StoryPop.Dialog.Alert" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/colorSurface</item>
    </style>

    <style name="Theme.StoryPop.BottomSheetDialog" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/colorSurface</item>
        <item name="bottomSheetStyle">@style/Widget.StoryPop.BottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <style name="Theme.StoryPop.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.StoryPop.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="ExpandedAppBar" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/mplus2_medium</item>
        <item name="android:shadowColor">@color/black_50</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>

    <style name="CollapsedAppBar" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/mplus2_regular</item>
    </style>

    <!-- ===== WIDGET STYLES (use semantic colors — auto switch) ===== -->

    <style name="Widget.StoryPop.ActionBar" parent="Widget.MaterialComponents.ActionBar.Primary">
        <item name="titleTextStyle">@style/TextAppearance.StoryPop.ActionBar.Title</item>
        <item name="subtitleTextStyle">@style/TextAppearance.StoryPop.ActionBar.Subtitle</item>
        <item name="background">@color/primaryColor</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="Widget.StoryPop.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/white_70</item>
        <item name="android:background">@color/primaryColor</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <style name="Widget.StoryPop.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/secondaryColor</item>
        <item name="rippleColor">@color/white_30</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">@font/mplus2_medium</item>
    </style>

    <style name="Widget.StoryPop.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/secondaryColor</item>
        <item name="rippleColor">@color/secondaryColor_20</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">@font/mplus2_medium</item>
    </style>

    <style name="Widget.StoryPop.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
    </style>

    <style name="Widget.StoryPop.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">@color/colorSurface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.StoryPop.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.StoryPop.BottomSheet" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <style name="Widget.StoryPop.PopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@color/colorSurface</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <style name="Widget.StoryPop.ProgressBar" parent="Widget.MaterialComponents.CircularProgressIndicator">
        <item name="indicatorColor">@color/secondaryColor</item>
        <item name="trackColor">#20FFFFFF</item>
    </style>

    <!-- ===== TEXT APPEARANCES ===== -->

    <style name="TextAppearance.StoryPop.ActionBar.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/mplus2_medium</item>
    </style>

    <style name="TextAppearance.StoryPop.ActionBar.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white_70</item>
        <item name="android:fontFamily">@font/mplus2_regular</item>
    </style>

    <style name="TextAppearance.StoryPop.Headline1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:fontFamily">@font/mplus2_medium</item>
    </style>

    <style name="TextAppearance.StoryPop.Headline2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:fontFamily">@font/mplus2_medium</item>
    </style>

    <style name="TextAppearance.StoryPop.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:fontFamily">@font/mplus2_regular</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.StoryPop.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:fontFamily">@font/mplus2_regular</item>
    </style>

    <style name="TextAppearance.StoryPop.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/mplus2_regular</item>
    </style>

    <style name="TextAppearance.StoryPop.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">@font/mplus2_medium</item>
    </style>
</resources>