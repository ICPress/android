<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/edit_nested_scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ArticleContentActivity"
    android:fillViewport="true"
    tools:showIn="@layout/activity_scrolling_edit">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:translationZ="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Author and Metadata Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp">

                <!-- Author Row -->
                <RelativeLayout
                    android:id="@+id/user_info_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="2dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/avatar_crop_cv"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/avatar_iv"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/user_solid_full"
                            android:translationZ="1dp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/username_post_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="8dp"
                        android:layout_toEndOf="@id/avatar_crop_cv"
                        android:text="&#64;username"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/time_passed_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="8dp"
                        android:layout_toEndOf="@id/username_post_tv"
                        android:text="@string/now"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:textStyle="italic" />
                </RelativeLayout>

                <!-- Location and Tags Edit Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/user_info_rv"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <!-- Location Section -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Location Button -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cv_location_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            app:cardElevation="1dp"
                            app:cardCornerRadius="18dp"

                            android:visibility="visible">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="16dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_maps_black"
                                    app:tint="@color/secondaryColor" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="Add location"
                                    android:textSize="12sp"
                                    android:textColor="@color/secondaryColor" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Location Edit (hidden initially) -->
                        <LinearLayout
                            android:id="@+id/ll_location_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/locationImg"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center_vertical"
                                android:src="@drawable/ic_maps_black"
                                app:tint="@color/textSecondary" />

                            <ProgressBar
                                android:id="@+id/location_pb"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="4dp"
                                android:indeterminateTint="@color/secondaryColor"
                                android:visibility="gone" />

                            <AutoCompleteTextView
                                android:id="@+id/location_ac_tv"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:hint="Location name"
                                android:textSize="14sp"
                                android:textColor="?android:textColorPrimary"
                                android:textColorHint="@color/textSecondary"
                                android:maxLength="70"
                                android:singleLine="true"
                                android:background="@null" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Tags Section -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Selected Tags -->
                            <com.google.android.flexbox.FlexboxLayout
                                android:id="@+id/tags_selected_flex"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                app:alignContent="center"
                                app:alignItems="center"
                                app:flexWrap="wrap"
                                app:justifyContent="flex_end">
                            </com.google.android.flexbox.FlexboxLayout>

                            <!-- Tag Input Section -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_below="@id/tags_selected_flex"
                                android:layout_marginTop="8dp">

                                <AutoCompleteTextView
                                    android:id="@+id/hashtags_ac_tv"
                                    android:layout_width="100dp"
                                    android:layout_height="36dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_centerVertical="true"
                                    android:hint="#tag"
                                    android:textSize="14sp"
                                    android:textColor="?android:textColorPrimary"
                                    android:textColorHint="@color/textSecondary"
                                    android:singleLine="true"
                                    android:gravity="center_vertical"
                                    android:paddingStart="0dp"
                                    android:paddingEnd="0dp" />

                                <androidx.cardview.widget.CardView
                                    android:id="@+id/add_tag_btn"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_toEndOf="@id/hashtags_ac_tv"
                                    android:layout_marginStart="4dp"
                                    android:layout_centerVertical="true"
                                    app:cardElevation="1dp"
                                    app:cardCornerRadius="18dp"
                                    app:cardBackgroundColor="@color/tagBackground"
                                    app:cardPreventCornerOverlap="false"
                                    app:contentPadding="0dp">

                                    <ImageView
                                        android:id="@+id/add_tag"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_gravity="center"
                                        android:padding="10dp"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ic_add"
                                        app:tint="@color/secondaryColor" />
                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:id="@+id/hashtag_warning_tv"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/hashtags_ac_tv"
                                    android:layout_marginTop="4dp"
                                    android:textSize="10sp"
                                    android:textColor="@color/colorError "
                                    android:visibility="gone" />
                            </RelativeLayout>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- AI Suggestion Button -->
            <RelativeLayout
                android:id="@+id/text_et_rl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp">

                <LinearLayout
                    android:id="@+id/text_et_suggestion_btn_rl"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/button_circle_white"
                    android:elevation="2dp"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_ai_pattern"
                        app:tint="@color/secondaryColor" />

                    <TextView
                        android:id="@+id/hashtag_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/need_writing_help"
                        android:textSize="12sp"
                        android:textColor="@color/secondaryColor"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Main Content EditText -->
                <net.crowdventures.storypop.MonitoringEditText
                    android:id="@+id/content_et"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/text_et_suggestion_btn_rl"
                    android:layout_marginTop="8dp"
                    android:minHeight="150dp"
                    android:fontFamily="@font/mplus2_regular"
                    android:hint="Write your story here..."
                    android:textSize="16dp"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="@color/textSecondary"
                    android:lineSpacingExtra="4dp"
                    android:maxLength="10000"
                    android:inputType="textAutoCorrect|textMultiLine"
                    android:background="@null" />
            </RelativeLayout>
        <LinearLayout
            android:id="@+id/sources_ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_et_rl"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- SOURCES SECTION -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/colorBorder" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp"
                android:text="Sources"
                android:textColor="@color/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Public Sources (Links) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Public Sources"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp"
                android:text="Add links to websites, articles, or public references"
                android:textColor="@color/textSecondary"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/public_sources_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Public sources will be added dynamically -->
            </LinearLayout>

            <Button
                android:id="@+id/add_public_source_btn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/secondaryColor_20"
                android:text="+ Add Public Source"
                android:textColor="@color/secondaryColor"
                android:textSize="12sp"
                app:cornerRadius="18dp" />

            <!-- Private Sources (Name/Address/Phone) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="Private Sources"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp"
                android:text="Add confidential source information (only visible to moderators)"
                android:textColor="@color/textSecondary"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/private_sources_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Private sources will be added dynamically -->
            </LinearLayout>

            <Button
                android:id="@+id/add_private_source_btn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/secondaryColor_20"
                android:text="+ Add Private Source"
                android:textColor="@color/secondaryColor"
                android:textSize="12sp"
                app:cornerRadius="18dp" />
        </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</androidx.core.widget.NestedScrollView>