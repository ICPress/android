<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:orientation="vertical"
    app:cardBackgroundColor="@color/surfaceLight"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardPreventCornerOverlap="true"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <!-- Header with professional styling -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/primaryColor">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Add Link"
                android:textColor="@color/textLight"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <ImageView
                android:id="@+id/close_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:padding="8dp"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@string/close"
                app:srcCompat="@drawable/ic_baseline_cancel_24"
                app:tint="@color/textLight" />
        </RelativeLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Instruction Text -->
            <TextView
                android:id="@+id/username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Enter your link details below"
                android:textAlignment="center"
                android:textColor="@color/secondaryTextColor"
                android:textSize="14sp"
                android:fontFamily="sans-serif" />

            <!-- Link Text Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxBackgroundColor="@color/white_10"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/secondaryColor"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/secondaryColor"
                app:placeholderTextColor="@color/secondaryTextColor">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/content_title_et"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="sans-serif"
                    android:hint="Link text"
                    android:inputType="text"
                    android:maxLength="60"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:singleLine="true"
                    android:textColor="@color/primaryTextColor"
                    android:textColorHint="@color/secondaryTextColor"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- URL Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:boxBackgroundColor="@color/white_10"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/secondaryColor"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="clear_text"
                app:hintTextColor="@color/secondaryColor"
                app:placeholderTextColor="@color/secondaryTextColor"
                app:startIconDrawable="@drawable/ic_link"
                app:startIconTint="@color/secondaryColor">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/content_et"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="sans-serif"
                    android:hint="https://example.com"
                    android:inputType="textUri"
                    android:maxLength="255"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:singleLine="true"
                    android:textColor="@color/primaryTextColor"
                    android:textColorHint="@color/secondaryTextColor"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:paddingTop="8dp">

                <Button
                    android:id="@+id/cancel_btn"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp"
                    android:text="Cancel"
                    android:textColor="@color/secondaryTextColor"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:backgroundTint="@android:color/transparent"
                    android:letterSpacing="0.05" />

                <Button
                    android:id="@+id/ok_btn"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:text="Add Link"
                    android:textColor="@color/textLight"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:backgroundTint="@color/secondaryColor"
                    android:letterSpacing="0.05"
                    app:cornerRadius="8dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:translationZ="0dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>