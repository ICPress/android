<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:background="?attr/colorSurface">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/avatar_crop_cv"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:elevation="1dp"
            app:cardCornerRadius="16dp">

            <ImageView
                android:id="@+id/avatar_iv"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerCrop"
                android:src="@drawable/user_solid_full" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/user_comment_info_lv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/avatar_crop_cv"
            android:layout_marginStart="6dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/username_post_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:textColor="@color/primaryTextColor"
                    android:text="&#64;username"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <ImageView
                    android:id="@+id/reply_to_iv"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="2dp"
                    android:scaleX="-1"
                    android:src="@drawable/baseline_reply_24"
                    app:tint="@color/secondaryTextColor"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/reply_username_post_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:layout_marginStart="2dp"
                    android:textColor="@color/secondaryColor"
                    android:text="&#64;username"
                    android:textSize="12sp"
                    android:focusable="true"
                    android:visibility="gone"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <net.crowdventures.storypop.TimeSinceTextView
                android:id="@+id/time_passed_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:gravity="end"
                android:text="@string/now"
                android:textColor="@color/secondaryTextColor"
                android:textSize="10sp"
                android:textStyle="italic" />
        </LinearLayout>

        <TextView
            android:id="@+id/comment_tv"
            android:layout_toEndOf="@id/avatar_crop_cv"
            android:layout_below="@id/user_comment_info_lv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="6dp"
            android:text="This is a comment"
            android:textSize="13sp"
            android:textColor="?android:textColorPrimary"
            android:lineSpacingExtra="2dp"
            android:textAppearance="?attr/textAppearanceBody2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/show_more"
            android:layout_below="@id/comment_tv"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="2dp"
            android:text="Show more"
            android:textSize="10sp"
            android:textColor="@color/secondaryColor"
            android:visibility="gone"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:icon="@drawable/baseline_expand_more_24"
            app:iconGravity="textEnd"
            app:iconPadding="2dp"
            app:iconSize="14dp"
            app:iconTint="@color/secondaryColor" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_comment_deleted"
            android:enabled="false"
            android:layout_toEndOf="@id/avatar_crop_cv"
            android:layout_below="@id/user_comment_info_lv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:text="This comment has been deleted"
            android:textSize="12sp"
            android:textColor="@color/secondaryTextColor"
            android:backgroundTint="@color/secondaryColor_20"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="8dp"
            app:rippleColor="@android:color/transparent"
            app:strokeColor="@color/border_color"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </RelativeLayout>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:paddingStart="38dp"
        android:baselineAligned="false">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_like"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="14dp"
            android:layout_margin="2dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?android:textColorPrimary"
            app:icon="@drawable/ic_baseline_favorite_border_24"
            app:iconGravity="textStart"
            app:iconPadding="2dp"
            app:iconSize="14dp"
            app:iconTint="@color/heart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reply"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="Reply"
            android:textColor="@color/secondaryColor"
            android:textSize="11sp"
            app:cornerRadius="14dp"
            app:icon="@drawable/baseline_reply_24"
            app:iconGravity="textStart"
            app:iconPadding="2dp"
            app:iconSize="14dp"
            app:iconTint="@color/secondaryColor" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="Hide"
            android:textColor="@color/secondaryTextColor"
            android:textSize="11sp"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_baseline_cancel_24"
            app:iconGravity="textStart"
            app:iconPadding="2dp"
            app:iconSize="14dp"
            app:iconTint="@color/secondaryTextColor" />
    </LinearLayout>

    <!-- Show Replies Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/white_70"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/secondaryColor"
        android:textSize="11sp"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

    <!-- Replies Container -->
    <RelativeLayout
        android:id="@+id/ll_replies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingStart="28dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_loader"
            style="?android:attr/progressBarStyle"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_centerHorizontal="true"
            android:indeterminateTint="@color/secondaryColor" />

        <LinearLayout
            android:id="@+id/comments_error_ll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_centerInParent="true"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            android:layout_below="@id/progress_loader">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_cloud_off_24"
                app:tint="@color/secondaryTextColor" />

            <TextView
                android:id="@+id/comments_error_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="8dp"
                android:text="Could not load replies"
                android:textSize="12sp"
                android:textColor="@color/secondaryTextColor" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comment_replies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/progress_loader"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_comment" />
    </RelativeLayout>

    <!-- Reply Preview Container -->
    <LinearLayout
        android:id="@+id/ll_reply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingStart="28dp"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comment_reply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_comment" />
    </LinearLayout>

    <!-- Reply Input Section -->
    <RelativeLayout
        android:id="@+id/comment_reply_rl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="28dp"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:id="@+id/author_badge_cv"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:elevation="1dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/avatar_background">

            <ImageView
                android:id="@+id/author_badge_iv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_solid_full" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/author_comment_info_lv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/author_badge_cv"
            android:layout_marginStart="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/username_author_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="username"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primaryColor" />

            <ImageView
                android:id="@+id/write_reply_to_iv"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="2dp"
                android:scaleX="-1"
                android:src="@drawable/baseline_reply_24"
                app:tint="@color/secondaryTextColor"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/write_reply_username_post_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:clickable="true"
                android:focusable="true"
                android:text="username"
                android:textSize="11sp"
                android:textColor="@color/secondaryColor"
                android:visibility="gone"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- ← Key fix: Widget.Material3.Button.IconButton replaced -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cancel_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="2dp"
                    app:backgroundTint="@android:color/transparent"
                    app:icon="@drawable/ic_baseline_cancel_24"
                    app:iconSize="16dp"
                    app:iconTint="@color/secondaryTextColor"
                    app:iconPadding="0dp"
                    app:iconGravity="textStart" />
            </RelativeLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_toEndOf="@id/author_badge_cv"
            android:layout_below="@id/author_comment_info_lv"
            android:layout_marginStart="6dp"
            android:layout_marginTop="2dp">

            <EditText
                android:id="@+id/comment_et"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="32dp"
                android:background="@null"
                android:hint="Write a reply..."
                android:textSize="12sp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="@color/secondaryTextColor"
                android:maxLength="500"
                android:padding="4dp"
                android:layout_marginEnd="4dp" />

            <!-- Plain Button is fine here — no icon attrs, no Material3 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/ok_btn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:enabled="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/secondaryColor"
                android:textColor="@color/white"
                android:text="Reply"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>