<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- ── Full-screen MapLibre MapView ── -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Top bar: back + title + save ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/primaryColor">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white "
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/mapTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Map Editor"
                android:textColor="@color/white "
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/mplus2_medium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:text="Save"
                android:textColor="@color/white "
                android:backgroundTint="@color/secondaryColor"
                app:icon="@drawable/ic_check_circle"
                app:iconGravity="textStart"
                app:cornerRadius="18dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Tool chip strip ── -->
    <HorizontalScrollView
        android:id="@+id/toolScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="80dp"
        android:scrollbars="none"
        android:paddingHorizontal="12dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/toolChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp" />
    </HorizontalScrollView>

    <!-- ── Undo / Redo FABs (bottom left) ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="80dp"
        android:orientation="vertical"
        android:background="@drawable/bg_fab_container"
        android:padding="8dp"
        android:elevation="4dp"
        app:cornerRadius="28dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabUndo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:fabSize="mini"
            app:backgroundTint="@color/primaryColor"
            app:srcCompat="@drawable/ic_undo"
            app:tint="@color/white "
            android:contentDescription="Undo" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRedo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            app:backgroundTint="@color/primaryColor"
            app:srcCompat="@drawable/ic_redo"
            app:tint="@color/white "
            android:contentDescription="Redo" />
    </LinearLayout>

    <!-- ── AI Suggestion FAB (bottom right) ── -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAiSuggestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:text="AI Suggest"
        android:textColor="@color/white "
        android:backgroundTint="@color/secondaryColor"
        app:icon="@drawable/ic_ai_pattern"
        app:iconGravity="textStart"
        app:cornerRadius="24dp" />

    <!-- ── Path-in-progress bottom bar ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/pathInProgressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/primaryColor">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_route"
                app:tint="#FFD700"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/pathPointsCountTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 points"
                android:textColor="@color/white "
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCommitPath"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_marginEnd="8dp"
                android:text="Done"
                android:textColor="@color/white "
                android:backgroundTint="@color/secondaryColor"
                app:icon="@drawable/ic_check_circle"
                app:iconGravity="textStart"
                app:cornerRadius="18dp"
                android:enabled="false" />

            <ImageButton
                android:id="@+id/btnCancelPath"
                android:layout_width="36dp"
                android:layout_height="45dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_baseline_cancel_24"
                app:tint="@color/white "
                android:contentDescription="Cancel path" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── AI Progress Container (bottom center) ── -->
    <LinearLayout
        android:id="@+id/aiProgressContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_ai_progress"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        android:elevation="8dp">

        <ProgressBar
            android:id="@+id/aiProgressBar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="@color/secondaryColor" />

        <TextView
            android:id="@+id/aiProgressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Analyzing article..."
            android:textColor="@color/white "
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ── AI Suggestion Dialog ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/aiSuggestionDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI Location Suggestion"
                android:textColor="@color/secondaryColor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Based on your article content, AI can suggest relevant locations to add to your map."
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/secondaryColor"
                app:hintTextColor="@color/secondaryColor">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/aiPromptEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Custom prompt (optional)"
                    android:text="Suggest locations, incidents, and routes based on this article"
                    android:maxLines="3"
                    android:inputType="textMultiLine"
                    android:textColor="@color/white " />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelAi"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:layout_marginEnd="8dp"
                    android:text="Cancel"
                    android:textColor="@color/textSecondary"
                    android:backgroundTint="@android:color/transparent"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerateAi"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:text="Generate"
                    android:textColor="@color/white "
                    android:backgroundTint="@color/secondaryColor"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Screenshot Preview Dialog (simplified) ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/screenshotDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Map"
                android:textColor="@color/secondaryColor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Do you want to use this map for your article?"
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Screenshot Preview -->
            <ImageView
                android:id="@+id/screenshotPreview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"
                android:background="@color/primaryColor"
                android:scaleType="centerCrop"
                android:contentDescription="Map preview" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelScreenshot"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:layout_marginEnd="8dp"
                    android:text="Cancel"
                    android:textColor="@color/textSecondary"
                    android:backgroundTint="@android:color/transparent"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveScreenshot"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:text="Save Map"
                    android:textColor="@color/white "
                    android:backgroundTint="@color/secondaryColor"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>