<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nested_scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ArticleContentActivity"
    tools:showIn="@layout/activity_scrolling">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurface">

        <!-- Author and Metadata Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp">

            <!-- Author Row -->
            <RelativeLayout
                android:id="@+id/user_info_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="2dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/avatar_crop_cv"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/avatar_iv"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_solid_full" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/username_post_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:layout_toEndOf="@id/avatar_crop_cv"
                    android:text="&#64;username"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <net.crowdventures.storypop.TimeSinceTextView
                    android:id="@+id/time_passed_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:layout_toEndOf="@id/username_post_tv"
                    android:text="@string/now"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:textStyle="italic" />
            </RelativeLayout>

            <!-- Location and Tags Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/user_info_rv"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- Location -->
                <LinearLayout
                    android:id="@+id/location_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/locationImg"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_maps_black"
                        app:tint="@color/textSecondary" />

                    <TextView
                        android:id="@+id/location_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_gravity="center_vertical"
                        android:text="location"
                        android:textSize="14sp"
                        android:textColor="@color/textSecondary"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Tags -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.flexbox.FlexboxLayout
                        android:id="@+id/tags_selected_flex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        app:alignContent="center"
                        app:alignItems="center"
                        app:flexWrap="wrap"
                        app:justifyContent="flex_end">

                    </com.google.android.flexbox.FlexboxLayout>
                </RelativeLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- Article Content -->
        <net.crowdventures.storypop.ClickableImageSpanTextView
            android:id="@+id/content_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:fontFamily="@font/mplus2_regular"
            android:text="@string/large_text"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:lineSpacingExtra="4dp" />

        <LinearLayout
            android:id="@+id/sources_ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- SOURCES SECTION -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/colorBorder" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp"
                android:text="Sources"
                android:textColor="@color/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Public Sources (Links) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Public Sources"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/public_sources_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Public sources will be added dynamically -->
            </LinearLayout>
            <TextView
                android:id="@+id/private_sources_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="Private Sources"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/private_sources_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:visibility="gone">

                <!-- Private sources will be added dynamically -->
            </LinearLayout>
        </LinearLayout>
        <!-- Author Footer Section -->
        <RelativeLayout
            android:id="@+id/user_info_rv_big"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/divider"
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_centerHorizontal="true"
                android:background="@color/primaryColor"
                android:layout_marginBottom="20dp" />

            <RelativeLayout
                android:id="@+id/author_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/divider"
                android:padding="8dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/avatar_crop_big_cv"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    >

                    <ImageView
                        android:id="@+id/avatar_crop_big_iv"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_solid_full" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/username_post_big_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="100dp"
                    android:layout_toEndOf="@id/avatar_crop_big_cv"
                    android:layout_alignTop="@id/avatar_crop_big_cv"
                    android:text="&#64;username"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/author_followers_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/username_post_big_tv"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_toEndOf="@id/avatar_crop_big_cv"
                    android:text="~10 Followers"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:visibility="invisible"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/subscribe_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:text="FOLLOW"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/btn_follow_text_tint"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/btn_follow_tint"
                    app:cornerRadius="18dp"
                    app:rippleColor="@color/secondaryLightColor"
                    app:iconGravity="textStart"
                    app:icon="@drawable/ic_add"
                    app:iconTint="@color/white"
                    app:iconSize="16dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    style="@style/Widget.MaterialComponents.Button" />


            </RelativeLayout>

            <!-- Action Buttons -->
            <RelativeLayout
                android:id="@+id/article_nav_bar_ll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/author_info"
                android:layout_marginTop="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:text="SHARE"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/secondaryColor"
                    app:icon="@drawable/baseline_share_24"
                    app:iconGravity="textStart"
                    app:iconTint="@color/secondaryColor"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_write_comment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Write a comment..."
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/secondaryColor"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="8dp"
                    app:icon="@drawable/baseline_add_comment_24"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:iconTint="@color/secondaryColor"
                    app:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </RelativeLayout>

            <!-- Progress Loader -->
            <ProgressBar
                android:id="@+id/progress_loader"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/article_nav_bar_ll"
                android:layout_marginTop="20dp"
                android:indeterminateTint="@color/secondaryColor"
                android:visibility="visible" />
        </RelativeLayout>

        <!-- Comments Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/comments_header_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comments"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:textColorPrimary" />

            <TextView
                android:id="@+id/comments_count_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/comments_header_tv"
                android:layout_marginStart="8dp"
                android:layout_gravity="center_vertical"
                android:text="(0)"
                android:textSize="14sp"
                android:textColor="@color/textSecondary" />

            <!-- Comments Error -->
            <LinearLayout
                android:id="@+id/comments_error_ll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/comments_count_tv"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/baseline_cloud_off_24"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/comments_error_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="12dp"
                    android:text="Could not load comments, please check your connection."
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Comments RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="150dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_comment" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>