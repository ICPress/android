<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:orientation="vertical"
    app:cardBackgroundColor="@color/surfaceLight"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardPreventCornerOverlap="true"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <!-- Header with icon area and close button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/primaryColor">

            <!-- Optional Icon Container (can be shown/hidden programmatically) -->
            <FrameLayout
                android:id="@+id/icon_container"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_centerInParent="true"
                android:background="@color/white_20"
                android:visibility="gone"
                app:cornerRadius="28dp">

                <ImageView
                    android:id="@+id/dialog_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_info_outline"
                    android:tint="@color/textLight" />
            </FrameLayout>

            <ImageView
                android:id="@+id/close_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:padding="8dp"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/close"
                app:srcCompat="@drawable/ic_baseline_cancel_24"
                app:tint="@color/textLight" />

        </RelativeLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Main title/question text -->
            <TextView
                android:id="@+id/dialog_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Dialog Title"
                android:textAlignment="center"
                android:textColor="@color/primaryTextColor"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="4sp"
                android:visibility="gone" />

            <!-- Main error/question text (primary message) -->
            <TextView
                android:id="@+id/error_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Primary message"
                android:textAlignment="center"
                android:textColor="@color/primaryTextColor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="4sp" />

            <!-- Secondary/helper text -->
            <TextView
                android:id="@+id/text2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Additional context or instructions"
                android:textAlignment="center"
                android:textColor="@color/secondaryTextColor"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="4sp"
                android:visibility="visible" />

            <!-- Optional Input Field (can be shown/hidden programmatically) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:boxBackgroundColor="@color/white_10"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/secondaryColor"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/secondaryColor"
                app:placeholderTextColor="@color/secondaryTextColor"
                app:startIconDrawable="@drawable/ic_input"
                app:startIconTint="@color/secondaryColor">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_field"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="sans-serif"
                    android:hint="Enter your response"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:singleLine="true"
                    android:textColor="@color/primaryTextColor"
                    android:textColorHint="@color/secondaryTextColor"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Optional Divider -->
            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="@color/border_color"
                android:visibility="gone" />

            <!-- Button row with flexible layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="8dp">

                <!-- Cancel button - can be hidden if not needed -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cancel_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:text="@android:string/cancel"
                    android:textColor="@color/secondaryTextColor"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:backgroundTint="@android:color/transparent"
                    android:letterSpacing="0.05"
                    android:visibility="visible"
                    app:cornerRadius="8dp" />

                <!-- Neutral/Alternative button (optional) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/neutral_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:text="Neutral"
                    android:textColor="@color/secondaryColor"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/secondaryColor"
                    app:strokeWidth="1dp" />

                <!-- Confirm/OK button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ok_btn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="0dp"
                    android:text="Confirm"
                    android:textColor="@color/textLight"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:backgroundTint="@color/secondaryColor"
                    android:letterSpacing="0.05"
                    app:cornerRadius="8dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:translationZ="0dp"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

            <!-- Single button layout (alternative when only one button is needed) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/single_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="OK"
                android:textColor="@color/textLight"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/secondaryColor"
                android:letterSpacing="0.05"
                android:visibility="gone"
                app:cornerRadius="8dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:translationZ="0dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>