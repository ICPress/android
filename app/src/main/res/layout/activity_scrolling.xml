<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="1dp"
        tools:context=".ArticleContentActivity">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/Theme.StoryPop.AppBarOverlay">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/toolbar_layout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_250sdp"
                app:contentScrim="@color/primaryColor"
                app:layout_scrollFlags="scroll|exitUntilCollapsed"
                app:expandedTitleGravity="right"
                app:collapsedTitleGravity="right"
                app:toolbarId="@+id/toolbar"
                app:expandedTitleTextAppearance="@style/ExpandedAppBar"
                app:collapsedTitleTextAppearance="@style/CollapsedAppBar">

                <RelativeLayout
                    android:id="@+id/titleContent_rl"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:minHeight="@dimen/_250sdp"
                    app:layout_collapseMode="parallax">

                    <!-- Full-bleed hero image (hidden when map is shown) -->
                    <ImageView
                        android:id="@+id/content_title_iv"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_250sdp"
                        android:scaleType="centerCrop"
                        android:src="@color/primaryDarkColor"
                        android:visibility="gone" />

                    <!-- Map Container (shown when storyMap is not null) -->
                    <FrameLayout
                        android:id="@+id/map_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:minHeight="@dimen/_250sdp"
                        android:visibility="gone">

                        <org.maplibre.android.maps.MapView
                            android:id="@+id/map_preview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <!-- Expand button for fullscreen -->
                        <ImageButton
                            android:id="@+id/btn_expand_map"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="12dp"
                            android:background="@drawable/bg_expand_button"
                            android:contentDescription="Expand map"
                            android:src="@drawable/enlarge_increase_icon" />


                    </FrameLayout>

                    <!-- Title pinned to bottom -->
                    <TextView
                        android:id="@+id/content_title_tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="72dp"
                        android:paddingBottom="16dp"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:fontFamily="@font/mplus2_medium"
                        android:text="Your story"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:lineSpacingMultiplier="1.2"
                        android:shadowColor="@color/black"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="4" />

                </RelativeLayout>

            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <include layout="@layout/content_scrolling" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/fab_margin"
            app:layout_anchor="@id/app_bar"
            app:layout_anchorGravity="bottom|end"
            app:backgroundTint="@color/white"
            app:srcCompat="@drawable/ic_baseline_favorite_border_24"
            app:tint="@color/heart"
            android:contentDescription="@string/like_article" />

        <!-- Admin Moderation FAB Container -->
        <LinearLayout
            android:id="@+id/admin_fab_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/fab_margin"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                android:id="@+id/accept_fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Accept"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/success"
                app:icon="@drawable/ic_check_circle"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="20dp"
                app:iconTint="@color/white"
                app:cornerRadius="24dp"
                style="@style/Widget.MaterialComponents.ExtendedFloatingActionButton" />

            <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                android:id="@+id/reject_fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reject"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/error"
                app:icon="@drawable/ic_info_outline"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="20dp"
                app:iconTint="@color/white"
                app:cornerRadius="24dp"
                style="@style/Widget.MaterialComponents.ExtendedFloatingActionButton" />

        </LinearLayout>

        <!-- TikTok-style bottom comment bar -->
        <FrameLayout
            android:id="@+id/standard_bottom_sheet"
            app:behavior_hideable="true"
            android:layout_height="wrap_content"
            android:layout_width="fill_parent"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
            <include layout="@layout/bottom_comment_bar" android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </FrameLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</RelativeLayout>